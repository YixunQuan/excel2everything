{# Hive DDL Template - 建表语句 #}
-- ============================================================
-- Table: {{ model.table_name }}
-- Description: {{ model.table_label }}
-- Generated by excel2sql
-- ============================================================

{% if model.drop_if_exists %}
DROP TABLE IF EXISTS {{ model.table_name }};
{% endif %}

CREATE TABLE {{ model.table_name }} (
{%- for col in model.columns %}
    {{ col.name }}    {{ col.data_type | replace("VARCHAR2", "STRING") | replace("NUMBER", "DECIMAL(18,6)") | replace("DATE", "STRING") }} COMMENT '{{ col.label }}'{{ "," if not loop.last else "" }}
{%- endfor %}
)
COMMENT '{{ model.table_label }}'
{% if model.partition_by %}
PARTITIONED BY ({{ model.partition_by }} STRING)
{% endif %}
STORED AS ORC
TBLPROPERTIES ('orc.compress'='SNAPPY');
