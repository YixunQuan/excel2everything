{# MySQL DDL Template - 建表语句 #}
-- ============================================================
-- Table: {{ model.table_name }}
-- Description: {{ model.table_label }}
-- Generated by excel2sql
-- ============================================================

{% if model.drop_if_exists %}
DROP TABLE IF EXISTS {{ model.table_name }};
{% endif %}

CREATE TABLE {{ model.table_name }} (
{%- for col in model.columns %}
    {{ col.name }}    {{ col.data_type | replace("VARCHAR2", "VARCHAR") | replace("NUMBER", "DECIMAL") | replace("DATE", "DATETIME") }}{% if not col.is_nullable %} NOT NULL{% endif %}{% if col.default_value %} DEFAULT {{ col.default_value }}{% endif %} COMMENT '{{ col.label }}'{{ "," if not loop.last else "" }}
{%- endfor %}
{% if model.primary_key %},
    PRIMARY KEY ({% for pk in model.primary_key %}{{ pk }}{{ ", " if not loop.last else "" }}{% endfor %})
{%- endif %}
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='{{ model.table_label }}';
