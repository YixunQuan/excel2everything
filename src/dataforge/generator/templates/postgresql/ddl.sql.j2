{# PostgreSQL DDL Template - 建表语句 #}
-- ============================================================
-- Table: {{ model.table_name }}
-- Description: {{ model.table_label }}
-- Generated by excel2sql
-- ============================================================

{% if model.drop_if_exists %}
DROP TABLE IF EXISTS {{ model.table_name }} CASCADE;
{% endif %}

CREATE TABLE {{ model.table_name }} (
{%- for col in model.columns %}
    {{ col.name }}    {{ col.data_type | replace("VARCHAR2", "VARCHAR") | replace("NUMBER", "NUMERIC") }}{% if not col.is_nullable %} NOT NULL{% endif %}{% if col.default_value %} DEFAULT {{ col.default_value }}{% endif %}{{ "," if not loop.last else "" }}
{%- endfor %}
{% if model.primary_key %},
    CONSTRAINT pk_{{ model.table_name | lower }} PRIMARY KEY ({% for pk in model.primary_key %}{{ pk }}{{ ", " if not loop.last else "" }}{% endfor %})
{%- endif %}
);

-- Table Comment
COMMENT ON TABLE {{ model.table_name }} IS '{{ model.table_label }}';

-- Column Comments
{% for col in model.columns %}
{% if col.label %}
COMMENT ON COLUMN {{ model.table_name }}.{{ col.name }} IS '{{ col.label }}';
{% endif %}
{% endfor %}
